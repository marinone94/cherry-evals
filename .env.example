# Google Gemini API Key (required — used for embeddings and light LLM tasks)
GOOGLE_API_KEY=your-google-api-key
# Disable VertexAI by default, use Gemini API instead for early development
GOOGLE_GENAI_USE_VERTEXAI=0

# Anthropic API Key (required — used for reasoning tasks)
ANTHROPIC_API_KEY=sk-ant-xxx

# Cerebras API Key (optional — used for fast inference)
CEREBRAS_API_KEY=csk-xxx

# Database connections
# Local: postgresql://cherry:cherry@localhost:5433/cherry_evals
# Neon:  postgresql://user:pass@host/db?sslmode=require  (SQLAlchemy handles SSL automatically)
DATABASE_URL=postgresql://cherry:cherry@localhost:5433/cherry_evals
QDRANT_URL=http://localhost:6333
# Qdrant Cloud API key (leave empty for local Qdrant, set for Qdrant Cloud)
QDRANT_API_KEY=

# Langfuse tracing (optional)
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional overrides
CHERRY_DATA_DIR=./data
CHERRY_LOG_LEVEL=INFO
